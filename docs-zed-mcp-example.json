{
  "context_servers": {
    "pac-local": {
      "source": "custom",
      "command": "C:/tools/pac.exe",
      "args": [
        "--base-url",
        "https://localhost",
        "--insecure"
      ],
      "env": {}
    },
    "pac-https": {
      "source": "custom",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://localhost/mcp",
        "--insecure"
      ],
      "env": {}
    }
  }
}
