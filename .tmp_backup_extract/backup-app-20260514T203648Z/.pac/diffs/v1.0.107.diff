+/* v1.0.108: 2-column configuration page layout */
+.providers-overview-layout,
+.profiles-overview-layout,
+.workspaces-overview-layout,
+.tools-overview-layout,
+.sessions-overview-layout {
+  display: grid;
+  grid-template-columns: 1fr 340px;
+  gap: 1rem;
+  align-items: start;
+}
+.providers-left,
+.profiles-left,
+.workspaces-left,
+.tools-left,
+.sessions-left {
+  display: flex;
+  flex-direction: column;
+  gap: 0;
+}
+.providers-right-panel,
+.profiles-right-panel,
+.workspaces-right-panel,
+.tools-right-panel,
+.sessions-right-panel {
+  position: sticky;
+  top: 55px;
+}
+.providers-right-panel h2,
+.profiles-right-panel h2,
+.workspaces-right-panel h2,
+.tools-right-panel h2,
+.sessions-right-panel h2 {
+  font-size: .95rem;
+  letter-spacing: .06em;
+  text-transform: uppercase;
+  margin-bottom: .6rem;
+}
+.profiles-list-item,
+.workspaces-list-item,
+.tools-list-item {
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: .65rem .75rem;
+  margin-bottom: .45rem;
+  background: rgba(15,23,42,.70);
+  cursor: pointer;
+}
+.profiles-list-item:hover,
+.workspaces-list-item:hover,
+.tools-list-item:hover {
+  background: rgba(15,23,42,.80);
+}
+.profiles-list-item code,
+.workspaces-list-item code,
+.tools-list-item code {
+  font-size: .8rem;
+}
+@media (max-width: 1100px) {
+  .providers-overview-layout,
+  .profiles-overview-layout,
+  .workspaces-overview-layout,
+  .tools-overview-layout,
+  .sessions-overview-layout {
+    grid-template-columns: 1fr;
+  }
+  .providers-right-panel,
+  .profiles-right-panel,
+  .workspaces-right-panel,
+  .tools-right-panel,
+  .sessions-right-panel {
+    position: static;
+  }
+}
+
+/* v1.0.108: flat slate modals (removed gradient) */
+.modal-card {
+  background: rgba(15,23,42,.70);
+}
+
+/* Model cards */
+#models-configured { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: .6rem; }
+.model-card {
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  background: rgba(15,23,42,.70);
+  padding: .7rem .8rem;
+  cursor: pointer;
+  overflow: hidden;
+}
+.model-card:hover { background: rgba(15,23,42,.85); border-color: var(--accent); }
+.model-card-unavailable { opacity: .6; }
+.model-card-header { margin-bottom: .5rem; }
+.model-card-name-row { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
+.model-card-name { font-size: 1rem; font-weight: 600; color: #f4f1ff; }
+.model-provider-badge { font-size: .7rem; background: var(--accent); color: white; padding: .1rem .4rem; border-radius: 3px; }
+.model-card-body { display: flex; flex-direction: column; gap: .4rem; }
+.model-card-meta { display: flex; gap: .75rem; flex-wrap: wrap; }
+.model-meta-item { display: flex; flex-direction: column; gap: .1rem; font-size: .78rem; }
+.model-meta-item .muted { font-size: .7rem; }
+.model-card-caps { display: flex; flex-wrap: wrap; gap: .3rem; }
+.model-cap-tag { font-size: .65rem; padding: .15rem .4rem; border-radius: 3px; border: 1px solid; }
+.model-card-context { display: flex; gap: .75rem; flex-wrap: wrap; }
+.model-card-lm-settings { font-size: .7rem; color: var(--muted); padding-top: .3rem; border-top: 1px solid var(--border); }
+.model-card .button-row { margin-top: .4rem; }
+
+/* Score indicators */
+.model-score-indicators { display: flex; gap: .3rem; align-items: center; }
+.score-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; cursor: help; }
+.score-null { background: #374151; }
+.score-ok { background: var(--ok); }
+.score-warn { background: var(--warn); }
+.score-bad { background: var(--danger); }
+
+/* Active sessions panel */
