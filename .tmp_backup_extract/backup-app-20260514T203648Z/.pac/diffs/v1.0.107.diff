+    def verify_password(self, password: str) -> bool:
+        import hashlib, secrets
+        if not self.password_hash or '::' not in self.password_hash:
+            return False
+        salt_hex, stored_hash_hex = self.password_hash.split('::')
+        salt = bytes.fromhex(salt_hex)
