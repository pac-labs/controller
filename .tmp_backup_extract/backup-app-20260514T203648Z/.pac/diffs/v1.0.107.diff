+
+/* Settings submenu */
+.settings-subnav { display:flex; flex-wrap:wrap; gap:.4rem; margin-bottom:1.1rem; padding-bottom:.75rem; border-bottom:1px solid var(--border); }
+.settings-sub-btn { background:rgba(15,23,42,.65); border:1px solid var(--border); border-radius:var(--radius); padding:.45rem .9rem; color:var(--muted); font-size:.8rem; cursor:pointer; transition:all .15s; }
+.settings-sub-btn:hover { border-color:var(--accent); color:var(--text); }
+.settings-sub-btn.active { background:rgba(109,69,214,.25); border-color:var(--accent-strong); color:var(--text); }
+.settings-panel { display:none }
+.settings-panel.active { display:block }
+.settings-panel-inner { display:grid; grid-template-columns:1fr 320px; gap:1.2rem; align-items:start }
+.settings-panel-inner .settings-main { min-width:0 }
+.settings-panel-inner .settings-detail-panel { background:rgba(15,23,42,.65); border:1px solid var(--border); border-radius:var(--radius); padding:.85rem; }
+.settings-panel-inner .settings-detail-panel h3 { margin:0 0 .6rem; font-size:.9rem; }
+.settings-panel-inner .compact-form { display:grid; grid-template-columns:1fr 1fr; gap:.55rem .75rem; }
+.settings-panel-inner .compact-form label { display:flex; flex-direction:column; gap:.2rem; font-size:.78rem; color:var(--muted); }
+.settings-panel-inner .compact-form input, .settings-panel-inner .compact-form select, .settings-panel-inner .compact-form textarea { background:rgba(10,8,22,.55); border:1px solid var(--border); border-radius:6px; padding:.4rem .6rem; color:var(--text); font-size:.82rem; width:100%; box-sizing:border-box; }
+.settings-panel-inner .compact-form input[type=checkbox] { width:auto; }
+@media(max-width:1100px) { .settings-panel-inner { grid-template-columns:1fr; } .settings-panel-inner .settings-detail-panel { display:none; } }
+
+/* Users list */
+.users-list { display:flex; flex-direction:column; gap:.5rem; }
+.user-row { display:flex; align-items:center; justify-content:space-between; background:rgba(15,23,42,.65); border:1px solid var(--border); border-radius:var(--radius); padding:.65rem .85rem; gap:.75rem; }
+.user-row-info { display:flex; flex-direction:column; gap:.15rem; min-width:0 }
+.user-row-name { font-size:.88rem; font-weight:600; }
+.user-row-meta { font-size:.72rem; color:var(--muted); }
+.user-row-actions { display:flex; gap:.4rem; flex-shrink:0; }
+.role-badge { display:inline-block; padding:.15rem .5rem; border-radius:20px; font-size:.68rem; font-weight:700; text-transform:uppercase; }
+.role-badge.admin { background:rgba(109,69,214,.3); color:#c4a3ff; border:1px solid rgba(109,69,214,.5); }
+.role-badge.user { background:rgba(32,130,80,.25); color:#6dffa0; border:1px solid rgba(32,130,80,.45); }
+.role-badge.readonly { background:rgba(50,80,130,.25); color:#80b4ff; border:1px solid rgba(50,80,130,.45); }
+
+/* Memory list */
+.memory-list { display:flex; flex-direction:column; gap:.4rem; }
+.memory-row { display:flex; align-items:center; justify-content:space-between; background:rgba(15,23,42,.65); border:1px solid var(--border); border-radius:var(--radius); padding:.5rem .75rem; gap:.5rem; font-size:.8rem; }
+.memory-row-name { font-weight:600; font-size:.82rem; }
+.memory-row-meta { font-size:.72rem; color:var(--muted); }
+.memory-row-actions { display:flex; gap:.3rem; }
+
+/* Registry list */
+.registry-list { display:flex; flex-direction:column; gap:.4rem; }
+.registry-image-row { display:flex; align-items:center; justify-content:space-between; background:rgba(15,23,42,.65); border:1px solid var(--border); border-radius:var(--radius); padding:.6rem .85rem; gap:.75rem; cursor:pointer; transition:border-color .15s; }
+.registry-image-row:hover { border-color:var(--accent); }
+.registry-image-row.selected { border-color:var(--accent-strong); background:rgba(109,69,214,.12); }
+.registry-image-info { display:flex; flex-direction:column; gap:.15rem; min-width:0 }
+.registry-image-name { font-weight:600; font-size:.88rem; word-break:break-all; }
+.registry-image-meta { font-size:.72rem; color:var(--muted); }
