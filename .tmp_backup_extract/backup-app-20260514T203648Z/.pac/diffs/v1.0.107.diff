+  display: grid;
+  grid-template-columns: 1fr 320px;
+  gap: 20px;
+  align-items: start;
+}
+.updates-main > div { margin-bottom: 18px; }
+.updates-section-heading {
+  font-size: 0.75em;
+  font-weight: 600;
