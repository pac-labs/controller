+def _model_response_issue(raw: str, diagnostics: dict[str, Any] | None, parse_error: Exception | None = None) -> dict[str, Any]:
+    text = str(raw or '')
+    diag = diagnostics or {}
+    issue = {
+        "empty": not bool(text.strip()),
+        "malformed": parse_error is not None,
+        "finish_reason": diag.get("finish_reason"),
+        "likely_output_limited": bool(diag.get("likely_output_limited")),
+        "requested_max_tokens": diag.get("requested_max_tokens"),
+        "effective_max_tokens": diag.get("effective_max_tokens"),
+        "usage": diag.get("usage") or {},
+        "provider": diag.get("provider"),
+        "provider_type": diag.get("provider_type"),
+        "runtime_hints": diag.get("runtime_hints") or {},
+    }
+    if parse_error is not None:
+        issue["parse_error"] = str(parse_error)[:500]
+    if issue["likely_output_limited"]:
+        issue["resolution"] = "retry_with_strict_json_and_consider_larger_output_budget"
+    elif issue["empty"]:
+        issue["resolution"] = "retry_with_direct_response_request"
+    elif issue["malformed"]:
+        issue["resolution"] = "retry_with_strict_json_request"
+    else:
+        issue["resolution"] = "continue"
+    return issue
+
+
+def _model_limit_retry_budget(diagnostics: dict[str, Any] | None) -> int | None:
+    diag = diagnostics or {}
+    effective = int(diag.get("effective_max_tokens") or 0)
+    model_cap = int(((diag.get("runtime_hints") or {}).get("model_max_output_tokens")) or effective or 0)
+    if not effective or not model_cap or effective >= model_cap:
+        return None
+    return min(model_cap, max(effective + 512, int(effective * 1.5)))
