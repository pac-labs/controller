+def _download_online_update_asset(update: dict[str, Any], asset: str) -> Path:
+    if not update.get('ok'):
+        raise HTTPException(status_code=502, detail=update.get('error') or 'Online update check failed')
+    artifacts = update.get('artifacts') or {}
+    key = 'full_url' if asset == 'full' else 'patch_url'
+    url = artifacts.get(key)
+    if not url:
+        raise HTTPException(status_code=400, detail=f'No {asset} update asset URL was found in the release manifest')
+    updates_dir = pacp_path('updates', 'downloads')
+    updates_dir.mkdir(parents=True, exist_ok=True)
+    stamp = datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')
+    filename = f'{stamp}-{Path(str(artifacts.get("full" if asset == "full" else "patch") or "pac-patch.zip")).name}'
+    target = updates_dir / filename
+    req = urllib.request.Request(str(url), headers={'User-Agent': f'PAC/{PAC_VERSION}', 'Accept': 'application/zip,application/octet-stream,*/*'})
+    try:
+        with urllib.request.urlopen(req, timeout=90) as response:  # noqa: S310 - URL comes from configured release manifest
+            with target.open('wb') as out:
+                shutil.copyfileobj(response, out, length=1024 * 1024)
+    except Exception as exc:
+        raise HTTPException(status_code=502, detail=f'Could not download {asset} update asset: {exc}') from exc
+    try:
+        with zipfile.ZipFile(target) as zf:
