+# ---- Online controller update discovery -------------------------------------------
+
+_APP_UPDATE_CACHE: dict[str, Any] = {}
+
+
+def _version_tuple(value: str | None) -> tuple[int, ...]:
+    raw = str(value or '').strip().lstrip('v')
+    parts: list[int] = []
+    for chunk in re.split(r'[^0-9]+', raw):
+        if chunk == '':
+            continue
+        try:
+            parts.append(int(chunk))
+        except ValueError:
+            break
+    return tuple(parts) if parts else (0,)
+
+
+def _manifest_asset_url(manifest_url: str, asset_name: str) -> str:
+    base = manifest_url.rsplit('/', 1)[0]
+    return f'{base}/{asset_name}'
+
+
+def _fetch_json_url(url: str, timeout: int = 20) -> dict[str, Any]:
+    if not url or not url.startswith(('https://', 'http://')):
+        raise ValueError('Manifest URL must start with https:// or http://')
+    req = urllib.request.Request(url, headers={'User-Agent': f'PAC/{PAC_VERSION}', 'Accept': 'application/json'})
+    with urllib.request.urlopen(req, timeout=timeout) as response:  # noqa: S310 - user-configured release manifest URL
+        body = response.read(2 * 1024 * 1024)
+    data = json.loads(body.decode('utf-8'))
+    if not isinstance(data, dict):
+        raise ValueError('Manifest response was not a JSON object')
+    return data
+
+
+def _check_online_app_update(manifest_url: str | None = None, force: bool = False) -> dict[str, Any]:
+    app_updates = getattr(config, 'app_updates', None)
+    url = manifest_url or getattr(app_updates, 'latest_manifest_url', None)
+    if not url:
+        return {'ok': False, 'error': 'No app update manifest URL configured'}
+    cache_key = url
+    cache_minutes = max(0, int(getattr(app_updates, 'cache_minutes', 30) or 0)) if app_updates else 30
+    cached = _APP_UPDATE_CACHE.get(cache_key)
+    now = datetime.now(timezone.utc)
+    if cached and not force:
+        checked_at = cached.get('checked_at_dt')
+        if isinstance(checked_at, datetime) and cache_minutes and now - checked_at < timedelta(minutes=cache_minutes):
+            result = dict(cached.get('result') or {})
+            result['cached'] = True
+            return result
+    try:
+        manifest = _fetch_json_url(url)
+        remote_version = str(manifest.get('version') or manifest.get('release') or manifest.get('tag') or '').lstrip('v')
+        artifacts = manifest.get('artifacts') if isinstance(manifest.get('artifacts'), dict) else {}
+        patch_name = str(artifacts.get('patch') or getattr(app_updates, 'patch_asset_name', 'pac-patch.zip'))
+        full_name = str(artifacts.get('full') or getattr(app_updates, 'full_asset_name', 'pac-full.zip'))
+        changelog = manifest.get('changelog_entry') or manifest.get('changelog') or {}
+        current = PAC_VERSION
+        has_update = _version_tuple(remote_version) > _version_tuple(current)
+        result = {
+            'ok': True,
+            'repository': getattr(app_updates, 'repository', 'https://github.com/pac-labs/controller') if app_updates else 'https://github.com/pac-labs/controller',
+            'manifest_url': url,
+            'current_version': current,
+            'latest_version': remote_version or 'unknown',
+            'has_update': has_update,
+            'checked_at': now.isoformat(),
+            'artifacts': {
+                'patch': patch_name,
+                'full': full_name,
+                'patch_url': _manifest_asset_url(url, patch_name),
+                'full_url': _manifest_asset_url(url, full_name),
+                'changelog': artifacts.get('changelog') or 'PAC_CHANGELOG.json',
+            },
+            'changelog': changelog,
+            'manifest': manifest,
+            'cached': False,
+        }
+    except Exception as exc:
+        result = {'ok': False, 'error': str(exc), 'manifest_url': url, 'current_version': PAC_VERSION, 'checked_at': now.isoformat(), 'cached': False}
+    _APP_UPDATE_CACHE[cache_key] = {'checked_at_dt': now, 'result': result}
+    return result
+
