+.composer-left-actions,
+.composer-right-actions {
+  display:flex;
+  align-items:center;
+  gap:.42rem;
+  min-width:0;
+}
+.composer-right-actions { margin-left:auto; }
+.composer-footer-status {
+  min-width:0;
+  flex:1 1 auto;
+  color:#94a3b8;
+  font-size:.76rem;
+  overflow:hidden;
+  text-overflow:ellipsis;
+  white-space:nowrap;
+}
+.composer-shortcut-hint {
+  color:#64748b;
+  font-size:.72rem;
+  white-space:nowrap;
+}
+.session-composer .composer-icon-button.square.composer-round-action,
+.session-composer .composer-send-button.square.composer-send-round,
+.composer-mini-button {
+  height:2.15rem;
+  min-height:2.15rem;
+  border-radius:999px;
+  border:1px solid rgba(148,163,184,.20);
+  background:rgba(15,23,42,.86);
+  color:#e5e7eb;
+  box-shadow:none;
+}
+.session-composer .composer-icon-button.square.composer-round-action,
+.session-composer .composer-send-button.square.composer-send-round {
+  width:2.15rem;
+  min-width:2.15rem;
+  padding:0;
+}
+.composer-mini-button {
+  width:auto;
+  padding:0 .72rem;
+  font-size:.78rem;
+  font-weight:700;
+}
+.session-composer .composer-send-button.square.composer-send-round {
+  background:linear-gradient(180deg, rgba(34,197,94,.95), rgba(22,163,74,.92));
+  color:#04130a;
+  border-color:rgba(134,239,172,.62);
+}
+.session-composer .composer-send-button.square.composer-send-round:disabled {
+  opacity:.48;
+  cursor:not-allowed;
+  background:rgba(71,85,105,.42);
+  color:#94a3b8;
+  border-color:rgba(148,163,184,.12);
+}
+.composer-mini-button:hover,
+.session-composer .composer-icon-button.square.composer-round-action:hover {
+  background:rgba(30,41,59,.96);
+  color:#fff;
+}
+.composer-context-menu {
+  min-width:260px;
+  border-radius:16px;
+  background:rgba(15,23,42,.98);
+  color:#e5e7eb;
+  border-color:rgba(148,163,184,.22);
+}
+.composer-context-menu b { color:#cbd5e1; }
+.composer-context-menu button { color:#e5e7eb; border-radius:10px; }
+.composer-context-menu button:hover { background:rgba(59,130,246,.16); }
+.composer-permission-select {
+  width:auto !important;
+  max-width:9rem;
+  min-height:2.15rem !important;
+  height:2.15rem !important;
+  border-radius:999px !important;
+}
+#applySessionPermission.composer-mini-button {
+  min-height:2.15rem;
+  height:2.15rem;
+}
+.session-composer .composer-hint,
+#sessionEndpointLock.composer-hint {
+  width:min(980px, 100%);
+  margin:.35rem auto 0;
+  color:#7c8799;
+  overflow:hidden;
+  text-overflow:ellipsis;
+  white-space:nowrap;
+}
+@media(max-width:900px){
+  .composer-context-strip { gap:.32rem; }
+  .composer-pill { max-width:12rem; }
+  .session-composer .composer-controls.integrated.editor-like { align-items:stretch; flex-wrap:wrap; }
+  .composer-footer-status { order:3; flex-basis:100%; }
+  .composer-shortcut-hint { display:none; }
+}
+@media(max-width:620px){
+  .session-composer.chatgpt-composer { padding:.55rem .45rem; }
+  .session-composer .composer-panel { border-radius:18px; }
+  .composer-pill { max-width:100%; }
+  .composer-left-actions { flex-wrap:wrap; }
+  .composer-mini-button#composerDestinationButton { display:none; }
+}
